# ============================================================
# Lab Data Stack — Environment Variables
# ============================================================
# HOW TO USE:
#   1. Copy this file:    cp .env.example .env
#   2. Fill in all values below (replace every "changeme-...")
#   3. Restrict permissions: chmod 600 .env
#
# Generate secure random strings with:
#   openssl rand -base64 32
#
# NEVER commit your .env file to git — it is in .gitignore.
# ============================================================


# ────────────────────────────────────────────────────────────
# PostgreSQL — database credentials
# These are used by NocoDB, Superset, and PostgreSQL itself.
# ────────────────────────────────────────────────────────────
POSTGRES_USER=labuser
POSTGRES_PASSWORD=changeme-use-a-strong-password


# ────────────────────────────────────────────────────────────
# NocoDB — JWT signing secret
# Generate: openssl rand -base64 32
# ────────────────────────────────────────────────────────────
NOCODB_JWT_SECRET=changeme-generate-with-openssl-rand-base64-32


# ────────────────────────────────────────────────────────────
# Apache Superset — secret key and admin account
# The SECRET_KEY encrypts sessions and cookies.
# Generate: openssl rand -base64 42
# IMPORTANT: Once set, do not change SECRET_KEY — it will
#            invalidate all existing sessions.
# ────────────────────────────────────────────────────────────
SUPERSET_SECRET_KEY=changeme-generate-with-openssl-rand-base64-42

SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_EMAIL=admin@lab.local
SUPERSET_ADMIN_PASSWORD=changeme-use-a-strong-password
